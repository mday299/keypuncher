<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="protobuf2.AddressBook.AddressBookView">
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Name:" VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Width="200"/>

            <TextBlock Text="Email:" VerticalAlignment="Center"/>
            <TextBox x:Name="EmailBox" Width="200"/>

            <TextBlock Text="Phone:" VerticalAlignment="Center"/>
            <TextBox x:Name="PhoneBox" Width="200"/>

            <TextBlock Text="Type:" VerticalAlignment="Center"/>
            <ComboBox x:Name="PhoneTypeBox" Width="80">
                <ComboBoxItem Content="Mobile"/>
                <ComboBoxItem Content="Home"/>
                <ComboBoxItem Content="Work"/>
            </ComboBox>
        </StackPanel>

        <Button x:Name="AddButton" Content="Add Person" Margin="0,10,0,0"/>
        <ListBox x:Name="PeopleList" Height="150"/>
    </StackPanel>
</UserControl>
